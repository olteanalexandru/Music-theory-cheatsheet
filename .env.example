# Copy this file to .env.local and fill in your Supabase project's values
# (Project Settings -> API in the Supabase dashboard). Without these, the app
# still runs fully in guest mode - sign-in/account features are just hidden.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Only needed to run `npm run test:integration` (see README.md). This is a
# test-only credential - the Next.js app itself never reads it. Find it in
# Project Settings -> API -> service_role. Never commit a real value here.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: enables Google Drive storage for Play Along files. Create an OAuth
# 2.0 Client ID at console.cloud.google.com (type: Web application), add your
# domain to Authorized JavaScript origins, and enable the Google Drive API.
# Without this, Play Along file saving is disabled.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
